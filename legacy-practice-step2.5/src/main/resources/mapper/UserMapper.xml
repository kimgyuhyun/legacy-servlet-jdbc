<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.legacy.practice.step2.mapper.UserMapper">
    <select id="findAll" resultType="com.legacy.practice.step2.dto.UserDto">
        SELECT id, name, age, birth_date, address
        FROM `user`
        ORDER BY id ASC
    </select>
    <select id="findById"
            parameterType="long"
            resultType="com.legacy.practice.step2.dto.UserDto">
        SELECT id, name, age, birth_date, address, create_at, update_at
        FROM `user`
        WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="com.legacy.practice.step2.dto.UserDto">
        INSERT INTO `user` (name, age, birth_date, address)
        VALUES (#{name}, #{age}, #{birthDate}, #{address})
    </insert>
    <update id="updateById" parameterType="com.legacy.practice.step2.dto.UserDto">
        UPDATE `user`
        SET name = #{name},
            age = #{age},
            birth_date = #{birthDate},
            address = #{address}
        WHERE id = #{id}
    </update>
    <update id="updateNameById">
        UPDATE `user`
        SET name = #{name}
        WHERE id = #{id}
    </update>
    <select id="findByNameAndAddress" resultType="com.legacy.practice.step2.dto.UserDto">
        SELECT id, name, age, birth_date, address
        FROM `user`
        WHERE name LIKE CONCAT('%', #{name}, '%')
            AND address LIKE CONCAT('%', #{address}, '%')
        ORDER BY id ASC
    </select>
    <select id="findDynamicByNameAndAddress" resultType="com.legacy.practice.step2.dto.UserDto">
        SELECT id, name, age, birth_date, address
        FROM `user`
        <where>
            <choose>
                <when test="(name != null and name != '') or (address != null and address != '')">
                    <if test="name != null and name != ''">
                        AND name LIKE CONCAT('%', #{name}, '%')
                    </if>
                    <if test="address != null and address != ''">
                        AND address LIKE CONCAT('%', #{address}, '%')
                    </if>
                </when>
                <otherwise>
                    AND 1 = 0
                </otherwise>
            </choose>
        </where>
        ORDER BY id ASC
    </select>
</mapper>
